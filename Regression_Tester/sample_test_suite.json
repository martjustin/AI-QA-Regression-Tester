{
  "_schema_note": "This mirrors the columns expected in the Google Sheet 'Test Suite' tab consumed by the n8n workflow. dynamic_fields lists JSON paths that are allowed to vary run-to-run without triggering a hard fail. expected_key_values are the fields checked for exact match beyond schema/status.",
  "test_cases": [
    {
      "test_id": "TC-001",
      "test_name": "Login - valid credentials returns session token",
      "test_type": "api",
      "tags": ["smoke", "auth", "critical"],
      "priority": "critical",
      "active": true,
      "method": "POST",
      "endpoint": "https://api.example-shop.com/v1/auth/login",
      "headers": { "Content-Type": "application/json" },
      "body": { "email": "qa.regression@example.com", "password": "Test1234!" },
      "expected_status": 200,
      "expected_schema": {
        "type": "object",
        "required": ["token", "user_id", "expires_at"],
        "properties": {
          "token": { "type": "string" },
          "user_id": { "type": "string" },
          "expires_at": { "type": "string" }
        }
      },
      "expected_key_values": { "user_id": "usr_10293" },
      "dynamic_fields": ["token", "expires_at"],
      "known_flaky": false
    },
    {
      "test_id": "TC-002",
      "test_name": "Login - invalid password returns 401 with clear error",
      "test_type": "api",
      "tags": ["smoke", "auth"],
      "priority": "high",
      "active": true,
      "method": "POST",
      "endpoint": "https://api.example-shop.com/v1/auth/login",
      "headers": { "Content-Type": "application/json" },
      "body": { "email": "qa.regression@example.com", "password": "wrong-password" },
      "expected_status": 401,
      "expected_schema": {
        "type": "object",
        "required": ["error", "message"]
      },
      "expected_key_values": { "error": "invalid_credentials" },
      "dynamic_fields": [],
      "known_flaky": false,
      "notes": "Demo case: message wording intentionally changed server-side to test AI semantic-equivalence detection (e.g. 'Incorrect email or password' vs 'The credentials you entered are invalid')."
    },
    {
      "test_id": "TC-003",
      "test_name": "Product search - returns relevant results for 'running shoes'",
      "test_type": "api",
      "tags": ["search", "regression"],
      "priority": "medium",
      "active": true,
      "method": "GET",
      "endpoint": "https://api.example-shop.com/v1/search?q=running+shoes",
      "headers": {},
      "expected_status": 200,
      "expected_schema": {
        "type": "object",
        "required": ["results", "count"]
      },
      "expected_key_values": { "count_min": 5 },
      "dynamic_fields": ["results[].score", "results[].ad_id"],
      "known_flaky": false
    },
    {
      "test_id": "TC-004",
      "test_name": "Checkout - total price calculation with discount code",
      "test_type": "api",
      "tags": ["checkout", "critical", "regression"],
      "priority": "critical",
      "active": true,
      "method": "POST",
      "endpoint": "https://api.example-shop.com/v1/checkout/preview",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "cart_id": "cart_5521",
        "items": [{ "sku": "SHOE-RUN-42", "qty": 2, "unit_price": 79.99 }],
        "discount_code": "SAVE10"
      },
      "expected_status": 200,
      "expected_schema": {
        "type": "object",
        "required": ["subtotal", "discount_applied", "total", "currency"]
      },
      "expected_key_values": { "subtotal": 159.98, "discount_applied": 15.998, "total": 143.98, "currency": "USD" },
      "dynamic_fields": ["order_preview_id"],
      "known_flaky": false,
      "notes": "Demo case: seeded so 'actual' total comes back as 151.98 (discount not applied correctly) — should be classified REGRESSION, not stale expectation."
    },
    {
